<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="MapaTur.App.Views.Terrain3DView">
    <skia:SKGLView x:Name="Canvas" PaintSurface="OnPaintSurface">
        <skia:SKGLView.GestureRecognizers>
            <PanGestureRecognizer TouchPoints="1" PanUpdated="OnOrbitPan" />
            <PanGestureRecognizer TouchPoints="2" PanUpdated="OnTranslatePan" />
            <PinchGestureRecognizer PinchUpdated="OnPinch" />
        </skia:SKGLView.GestureRecognizers>
    </skia:SKGLView>
</ContentView>
