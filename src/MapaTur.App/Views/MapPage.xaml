<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:vm="clr-namespace:MapaTur.App.ViewModels"
             xmlns:loc="clr-namespace:MapaTur.App.Localization"
             xmlns:views="clr-namespace:MapaTur.App.Views"
             x:Class="MapaTur.App.Views.MapPage"
             x:DataType="vm:MapPageViewModel"
             Title="{x:Static loc:AppStrings.AppTitle}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="0">

        <HorizontalStackLayout Grid.Row="0" Padding="12" Spacing="12" BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#1F1F23}">
            <Button Text="{x:Static loc:AppStrings.OpenMBTiles}"
                    Command="{Binding OpenMBTilesCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.OpenMBTiles}" />
            <Button Text="{x:Static loc:AppStrings.OpenHillshade}"
                    Command="{Binding OpenHillshadeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.OpenHillshade}" />
            <Button Text="{x:Static loc:AppStrings.OpenTcx}"
                    Command="{Binding OpenTcxCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.OpenTcx}" />
            <Button Text="{x:Static loc:AppStrings.DownloadTrails}"
                    Command="{Binding DownloadTrailsForViewportCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.DownloadTrails}" />
            <Button Text="{x:Static loc:AppStrings.DownloadClimbing}"
                    Command="{Binding DownloadClimbingForViewportCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.DownloadClimbing}" />
            <Button Text="{x:Static loc:AppStrings.ClearRoute}"
                    Command="{Binding ClearRouteCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.ClearRoute}" />
            <Button Text="{x:Static loc:AppStrings.ExportGpx}"
                    Command="{Binding ExportRouteCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.ExportGpx}" />
            <Button Text="{x:Static loc:AppStrings.Toggle3D}"
                    Command="{Binding Toggle3DCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    SemanticProperties.Hint="{x:Static loc:AppStrings.Toggle3D}" />
            <!-- Vertical-exaggeration slider for 3D mode. Range 1..5 with snap at 0.5. -->
            <HorizontalStackLayout Spacing="6" VerticalOptions="Center" IsVisible="{Binding Is3DMode}">
                <Label Text="{x:Static loc:AppStrings.LabelVerticalExaggeration}"
                       VerticalOptions="Center" />
                <Slider Minimum="1"
                        Maximum="5"
                        Value="{Binding VerticalExaggeration, Mode=TwoWay}"
                        WidthRequest="140"
                        VerticalOptions="Center"
                        SemanticProperties.Hint="{x:Static loc:AppStrings.LabelVerticalExaggeration}" />
                <Label Text="{Binding VerticalExaggeration, StringFormat='{0:F1}×'}"
                       VerticalOptions="Center"
                       WidthRequest="42" />
            </HorizontalStackLayout>
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Trail filter row: 5 PTTK colour toggles + 4 Karpat region toggles. -->
        <HorizontalStackLayout Grid.Row="1" Padding="12,4" Spacing="6"
                               BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#27272A}">
            <Label Text="Kolory:" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding TrailColourRedEnabled}" Color="#DC2626" />
            <Label Text="Cz" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding TrailColourBlueEnabled}" Color="#2563EB" />
            <Label Text="Nb" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding TrailColourGreenEnabled}" Color="#16A34A" />
            <Label Text="Zi" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding TrailColourYellowEnabled}" Color="#EAB308" />
            <Label Text="Żo" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding TrailColourBlackEnabled}" Color="#27272A" />
            <Label Text="Cn" VerticalOptions="Center" FontSize="11" />
            <BoxView WidthRequest="1" HeightRequest="22" Color="#52525B" Margin="6,0" />
            <Label Text="Obszary:" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding RegionTatryEnabled}" />
            <Label Text="Tatry" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding RegionBeskidyEnabled}" />
            <Label Text="Beskidy" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding RegionPieninyEnabled}" />
            <Label Text="Pieniny" VerticalOptions="Center" FontSize="11" />
            <CheckBox IsChecked="{Binding RegionBieszczadyEnabled}" />
            <Label Text="Bieszczady" VerticalOptions="Center" FontSize="11" />
        </HorizontalStackLayout>

        <mapsui:MapControl x:Name="MapControl"
                           Grid.Row="2"
                           Map="{Binding Map}"
                           IsVisible="{Binding Is3DMode, Converter={StaticResource InverseBool}}"
                           SemanticProperties.Description="{x:Static loc:AppStrings.AccessibilityMapControl}" />

        <views:Terrain3DView x:Name="TerrainView"
                             Grid.Row="2"
                             Mesh="{Binding TerrainMesh}"
                             Raster="{Binding TerrainRaster}"
                             Trails="{Binding Trails3DOverlay}"
                             Route="{Binding Route3DOverlay}"
                             ClimbingAreas="{Binding Climbing3DOverlay}"
                             IsVisible="{Binding Is3DMode}" />

        <Label Grid.Row="3"
               Padding="12,8"
               Text="{Binding StatusMessage}"
               BackgroundColor="{AppThemeBinding Light=#F4F4F5, Dark=#1F1F23}"
               TextColor="{AppThemeBinding Light=#18181B, Dark=#FAFAFA}"
               SemanticProperties.HeadingLevel="Level2" />
    </Grid>

</ContentPage>
